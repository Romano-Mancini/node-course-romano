generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Type {
  FOOD
  DRINK
}

model User {
  id        String    @id @default(uuid())
  name      String
  surname   String    @default("undefined")
  email     String    @unique
  password  String
  products  Product[] @relation("UserProducts")
  recipes   Recipe[]  @relation("UserRecipes")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("users")
}

// a User can have zero or more products, a product must always have a user
// a Fridge can have zero or more products, a product must always have a fridge
model Product {
  id String @id @default(uuid())

  owner   User   @relation("UserProducts", fields: [ownerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  ownerId String

  fridge   Fridge @relation("FridgeProducts", fields: [fridgeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  fridgeId String

  name      String
  type      Type
  size      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("products")
}

model Fridge {
  id        String    @id @default(uuid())
  location  String
  capacity  Int
  products  Product[] @relation("FridgeProducts")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("fridges")
}

model Recipe {
  name        String
  description String
  ingredients String[]

  owner   User   @relation("UserRecipes", fields: [ownerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  ownerId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ownerId, name], name: "recipe_owner_name_unique")
  @@map("recipes")
}
